<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>net.keozx.rmmagent</string>

    <!-- A LaunchAgent (not a LaunchDaemon) so it runs in the user's GUI session
         and can show the tray icon + notification. -->
    <key>ProgramArguments</key>
    <array>
        <string>/Applications/Remote Support Agent.app/Contents/MacOS/Remote Support Agent</string>
    </array>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/rmmagent.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/rmmagent.err.log</string>
</dict>
</plist>