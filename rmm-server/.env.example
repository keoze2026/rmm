# Copy to .env and adjust. Never commit the real .env.
APP_NAME=RMM Server
ENV=development
DEBUG=true

HOST=0.0.0.0
PORT=8765

# PostgreSQL (local dev)
POSTGRES_USER=rmm
POSTGRES_PASSWORD=rmm
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rmm

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Generate a real secret:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

AGENT_TOKEN_BYTES=32
AGENT_OFFLINE_AFTER=30
